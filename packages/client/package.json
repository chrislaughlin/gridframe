{
  "name": "@gridframe/client",
  "version": "1.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run src",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@gridframe/eslint-config": "workspace:*",
    "@gridframe/typescript-config": "workspace:*",
    "eslint": "^9.39.1",
    "typescript": "5.9.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@gridframe/core": "workspace:*"
  }
}
